SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54402/postgres
API_JWT_SECRET=
GOOGLE_PLACES_API_KEY=
LOG_LEVEL=info
HEURISTIC_REFRESH_DAYS=30

DIRECTORY_REFRESH_DAYS=30
SOCIAL_SEARCH_REFRESH_DAYS=30
SOCIAL_ENRICH_CONCURRENCY=2
# PLAYWRIGHT_EXECUTABLEPATH=/snap/bin/chromium

# Enriquecimiento de métricas IG vía SearXNG self-hosted (opcional, $0).
# Default http://localhost:8080. Usado por el comando `ig-snippet-enrich`.
# SEARXNG_URL=http://localhost:8080

# Búsqueda social vía DuckDuckGo en el enrich (F4.2): OFF por defecto — DDG bloquea las
# consultas automáticas, el path vivo es ig-snippet-enrich (SearXNG). Activar solo para pruebas.
# ENABLE_DDG_SOCIAL_SEARCH=1

# UI -> API
NEXT_PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
PORT=3001

# Embed the PipelineScheduler (core worker) inside the API process.
# Con EMBED_SCHEDULER=true basta con 'pnpm --dir api dev' — no hace falta un proceso core separado.
# La UI en /admin/operations > Procesos puede iniciar/reiniciar el scheduler desde el browser.
EMBED_SCHEDULER=true

# Optional LLM config
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GOOGLE_GEMINI_API_KEY=
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_API_KEY=
# LLM_MODEL=
