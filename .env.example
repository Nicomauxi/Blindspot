SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54402/postgres
API_JWT_SECRET=
GOOGLE_PLACES_API_KEY=
LOG_LEVEL=info
HEURISTIC_REFRESH_DAYS=30

DIRECTORY_REFRESH_DAYS=30
SOCIAL_SEARCH_REFRESH_DAYS=30
SOCIAL_ENRICH_CONCURRENCY=2
# PLAYWRIGHT_EXECUTABLEPATH=/snap/bin/chromium

# UI -> API
NEXT_PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
PORT=3001

# Embed the PipelineScheduler (core worker) inside the API process.
# Con EMBED_SCHEDULER=true basta con 'pnpm --dir api dev' — no hace falta un proceso core separado.
# La UI en /admin/operations > Procesos puede iniciar/reiniciar el scheduler desde el browser.
EMBED_SCHEDULER=true

# Optional LLM config
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GOOGLE_GEMINI_API_KEY=
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_API_KEY=
# LLM_MODEL=

# Instagram Graph API — business_discovery (vía oficial, gratis, sin login wall).
# Inactivo si faltan estas dos: el comando `ig-graph-enrich` aborta con aviso.
# META_IG_USER_ID  = IG User ID de nuestra cuenta profesional (la "lente" que consulta)
# META_GRAPH_TOKEN = access token (long-lived o system user). Para consultar cuentas de
#   terceros hace falta App Review + Advanced Access + Business Verification.
# META_IG_USER_ID=
# META_GRAPH_TOKEN=
# META_GRAPH_VERSION=v21.0
# META_GRAPH_BASE_URL=https://graph.facebook.com
