SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_PLACES_API_KEY=
LOG_LEVEL=info
HEURISTIC_REFRESH_DAYS=30

DIRECTORY_REFRESH_DAYS=30
SOCIAL_SEARCH_REFRESH_DAYS=30
SOCIAL_ENRICH_CONCURRENCY=2
# PLAYWRIGHT_EXECUTABLEPATH=/snap/bin/chromium

# Embed the PipelineScheduler (Core worker) inside the API process.
# Con EMBED_SCHEDULER=true basta con 'pnpm --dir api dev' — no hace falta un proceso core separado.
# La UI en /admin/operations > Procesos puede iniciar/reiniciar el scheduler desde el browser.
EMBED_SCHEDULER=true
