{
  "name": "blindspot",
  "version": "1.0.0",
  "description": "Identify local businesses with strong offline reputation but poor digital presence",
  "type": "module",
  "bin": {
    "blindspot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm src/cli/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node --env-file=.env --import tsx/esm scripts/integration-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "prospecting",
    "google-places",
    "lead-generation"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "undici": "^7.0.0",
    "whoiser": "2.0.0-beta.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
