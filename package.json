{
  "name": "blindspot",
  "version": "1.0.0",
  "description": "Identify local businesses with strong offline reputation but poor digital presence",
  "type": "module",
  "bin": {
    "blindspot": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm src/cli/index.ts",
    "start:core": "node --env-file=.env --import tsx/esm src/start.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node --env-file=.env --import tsx/esm scripts/integration-test.ts",
    "smoke:api": "node --env-file=.env --import tsx/esm scripts/smoke-api.ts",
    "typecheck": "tsc --noEmit",
    "audit:data": "node --env-file=.env --import tsx/esm scripts/audit-data-quality.ts",
    "audit:reconcile": "node --env-file=.env --import tsx/esm scripts/audit-reconcile-plan.ts",
    "verify": "pnpm typecheck && pnpm --dir ui exec tsc --noEmit && pnpm test",
    "verify:full": "pnpm verify && pnpm --dir ui build && pnpm smoke:api"
  },
  "keywords": [
    "cli",
    "prospecting",
    "google-places",
    "lead-generation"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.105.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "undici": "^7.0.0",
    "whoiser": "2.0.0-beta.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
