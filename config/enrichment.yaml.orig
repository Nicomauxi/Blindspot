heuristic_discovery:
  enabled: true
  thresholds:
    website: 0.7
    social: 0.6
  tld_priority:
    - com.uy
    - uy
    - com
  max_candidates_to_probe: 6
  max_social_variants: 3
  city_suffixes:
    montevideo: mvd
  mobile_prefixes_uy:
    - "91"
    - "92"
    - "93"
    - "94"
    - "95"
    - "96"
    - "97"
    - "98"
    - "99"


directory_discovery:
  enabled: true
  source: yelu.uy
  min_confidence_to_use: 60
  fetch_profile_page: true
  niche_category_map:
    hairdresser: Peluqueros
    car_dealer: Concesionarios_de_Autos
    gym: Gimnasios
    restaurant: Restaurantes
    accommodation: Hoteles
    pharmacy: Farmacias
    grocery: Supermercados
    dentist: Dentistas
    healthcare: Medicos
    other: null
